# ============================================================
# VARIABLES DE ENTORNO — Sistema de Inspección MSL
# Copiar este archivo como .env y rellenar los valores
# NUNCA subir .env a GitHub
# ============================================================

# Base de datos PostgreSQL
# Local:     postgres://usuario:password@localhost:5432/inspeccion_msl
# Railway:   se copia desde el panel de Railway
DATABASE_URL=postgres://usuario:password@localhost:5432/inspeccion_msl

# Clave secreta para JWT (cambiar por una cadena larga y aleatoria)
JWT_SECRET=cambiar_por_clave_secreta_larga_y_aleatoria_aqui

# Entorno (development | production)
NODE_ENV=development

# Puerto del servidor (Railway lo asigna automáticamente)
PORT=3000

# URL del frontend (opcional, para CORS)
# FRONTEND_URL=https://tu-app.railway.app
